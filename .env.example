# =============================================================================
# StudioFlow — przykładowy plik konfiguracji środowiska
# Skopiuj jako .env i uzupełnij wartości oznaczone jako WYMAGANE.
# Nigdy nie commituj pliku .env do repozytorium.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL — baza danych
# -----------------------------------------------------------------------------

# Dane dostępowe do kontenera PostgreSQL (używane przez docker-compose).
POSTGRES_DB=ai_media_ops
POSTGRES_USER=ai_media_ops
POSTGRES_PASSWORD=ai_media_ops

# Pełny URL połączenia używany przez backend (FastAPI + SQLAlchemy).
# Przy uruchomieniu przez Docker Compose hostname to "postgres".
# Przy uruchomieniu lokalnym (bez Dockera) zmień na "localhost".
# WYMAGANE — bez tego backend próbuje połączyć się z postgres:5432 (może crashować).
DATABASE_URL=postgresql+asyncpg://ai_media_ops:ai_media_ops@postgres:5432/ai_media_ops


# -----------------------------------------------------------------------------
# Redis — broker tasków i backend wyników Celery
# -----------------------------------------------------------------------------

# Używane przez workera Celery. Przy Dockerze hostname to "redis".
# Przy uruchomieniu lokalnym zmień na "localhost".
# Uwaga: aktualnie wartości są zahardkodowane w apps/worker/worker_app.py —
# docelowo powinny być odczytywane stąd.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1


# -----------------------------------------------------------------------------
# Bezpieczeństwo i autoryzacja
# -----------------------------------------------------------------------------

# Lista kluczy API w formacie "klucz:rola,klucz2:rola2".
# Dostępne role: viewer, editor, admin, owner.
# WYMAGANE w środowisku produkcyjnym — bez tej zmiennej system działa w trybie
# dev_mode: każde żądanie dostaje rolę "owner" bez uwierzytelnienia.
# Przykład: AUTH_API_KEYS=supersecretkey:owner,readonlykey:viewer
AUTH_API_KEYS=

# Lista dozwolonych origin dla CORS, oddzielona przecinkami.
# Bez tej zmiennej nagłówki CORS nie są wysyłane (frontend w innej domenie nie zadziała).
# Przykład przy lokalnym developmencie:
CORS_ALLOWLIST=http://localhost:3000


# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------

# Maksymalna liczba żądań na okno czasowe (per IP + ścieżka).
RATE_LIMIT_MAX_REQUESTS=60

# Długość okna w sekundach.
RATE_LIMIT_WINDOW_SECONDS=60


# -----------------------------------------------------------------------------
# LLM — dostawca i modele
# -----------------------------------------------------------------------------

# Dostawca: "openai" (domyślnie) lub "local" (Ollama).
LLM_PROVIDER=openai

# Klucz API OpenAI.
# WYMAGANE gdy LLM_PROVIDER=openai — bez tego wywołania agentów zawiodą.
OPENAI_API_KEY=sk-...

# Modele dla poszczególnych agentów.
# Tańsze modele (gpt-4o-mini) do zadań prostszych, droższe (gpt-4o) do
# krytycznych etapów (skrypt, compliance). Wpływa bezpośrednio na koszt per projekt.
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_RESEARCH_MODEL=gpt-4o-mini
LLM_SCRIPT_MODEL=gpt-4o-mini
LLM_SEO_MODEL=gpt-4o-mini
LLM_COMPLIANCE_MODEL=gpt-4o-mini
LLM_CLASSIFIER_MODEL=gpt-4o-mini
LLM_PERFORMANCE_MODEL=gpt-4o-mini
LLM_SUMMARIZATION_MODEL=gpt-4o-mini


# -----------------------------------------------------------------------------
# LLM lokalny (Ollama) — opcjonalne
# -----------------------------------------------------------------------------

# Używane gdy LLM_PROVIDER=local lub jako fallback dla wybranych agentów.
# host.docker.internal to adres hosta z poziomu kontenera Docker (Mac/Windows).
# Na Linuxie użyj: http://172.17.0.1:11434/v1
LLM_LOCAL_BASE_URL=http://host.docker.internal:11434/v1
LLM_LOCAL_MODEL=qwen2.5:14b
