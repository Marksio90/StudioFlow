# =============================================================================
# StudioFlow Frontend — przykładowy plik konfiguracji środowiska
# Skopiuj jako .env.local i uzupełnij wartości.
# Zmienne NEXT_PUBLIC_* są widoczne po stronie przeglądarki.
# =============================================================================

# Adres backendu FastAPI.
# Przy uruchomieniu przez Docker Compose: http://localhost:8000
# Przy deploymencie produkcyjnym: https://api.twoja-domena.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Domyślny kontekst tenant używany przez frontend w nagłówkach żądań.
# Przy lokalnym developmencie można zostawić te wartości.
# W środowisku multi-tenant powinny być ustawiane per sesję/użytkownika.
NEXT_PUBLIC_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_CHANNEL_ID=00000000-0000-0000-0000-000000000001
