{
  "name": "ai-media-ops-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "generate:backend-contracts": "python3 ../backend/scripts/export_openapi.py && npm --prefix ../../packages/shared run generate:api",
    "check:backend-contracts": "npm run generate:backend-contracts && git diff --exit-code -- ../../packages/shared/openapi/backend.openapi.json ../../packages/shared/src/backend-api.ts"
  },
  "dependencies": {
    "next": "14.2.33",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.19.41",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18.3.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.33",
    "typescript": "5.9.3",
    "openapi-typescript": "^7.10.1"
  }
}
